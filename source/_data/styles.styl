// 1. 纯粹深渊底色：摒弃死黑，采用带有极客质感的深锌色
body {
  background-color: #09090b !important;
}

// 2. 核心质感：苹果级毛玻璃（Glassmorphism）卡片
.header-inner, .sidebar-inner, .post-block {
  background: rgba(24, 24, 27, 0.4) !important;
  backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}

// 3. 微交互律动：鼠标悬浮时的声波/雷达微光反馈
.post-block:hover {
  border: 1px solid rgba(165, 243, 252, 0.3);
  box-shadow: 0 0 25px rgba(165, 243, 252, 0.05);
  transform: translateY(-3px);
}

// 4. 让顶部的黑色进度条变成科技感的赛博蓝
.headband {
  background: linear-gradient(90deg, #0284c7, #06b6d4) !important;
  height: 3px !important;
}